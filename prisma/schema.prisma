// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String
  avatar        String?
  role          String    @default("user") // user, admin
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  invitations   Invitation[]
  billingOrders BillingOrder[]
  subscriptions Subscription[]
  paymentTransactions PaymentTransaction[]
  checkoutSessions CheckoutSession[]
}

model Invitation {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  brideName       String
  groomName       String
  templateId      String
  eventDate       DateTime
  eventTime       String
  eventLocation   String
  googleMapsUrl   String?
  story           String?
  musicUrl        String?
  isPublished     Boolean   @default(false)
  viewCount       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  
  template        Template  @relation(fields: [templateId], references: [id])
  
  gallery         Gallery[]
  rsvps           RSVP[]
  guests          Guest[]
  virtualGifts    VirtualGift[]
  liveStreams     LiveStream[]
}

model Gallery {
  id            String    @id @default(cuid())
  url           String
  caption       String?
  order         Int       @default(0)
  createdAt     DateTime  @default(now())
  
  invitationId  String
  invitation    Invitation @relation(fields: [invitationId], references: [id])
}

model RSVP {
  id            String    @id @default(cuid())
  name          String
  attending     Boolean
  guestCount    Int       @default(1)
  session       String?   // akad, reception, both
  menuPreference String?  // regular, vegetarian, kids, other
  dietaryNote   String?
  companionNames String?
  message       String?
  createdAt     DateTime  @default(now())
  
  invitationId  String
  invitation    Invitation @relation(fields: [invitationId], references: [id])
}

model Guest {
  id            String    @id @default(cuid())
  name          String
  phone         String?
  email         String?
  group         String?
  invitationUrl String?
  status        String    @default("pending") // pending, sent, opened
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  invitationId  String
  invitation    Invitation @relation(fields: [invitationId], references: [id])
  whatsappLogs  WhatsAppLog[]
}

model WhatsAppLog {
  id            String    @id @default(cuid())
  provider      String
  phone         String
  message       String
  status        String    @default("pending") // pending, sent, failed, fallback_link
  response      Json?
  createdAt     DateTime  @default(now())

  guestId       String?
  guest         Guest?    @relation(fields: [guestId], references: [id])
}

model VirtualGift {
  id            String    @id @default(cuid())
  type          String    @default("bank") // bank, ewallet, payment_gateway
  provider      String
  accountNumber String?
  accountName   String?
  qrImageUrl    String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  invitationId  String
  invitation    Invitation @relation(fields: [invitationId], references: [id])
}

model LiveStream {
  id            String    @id @default(cuid())
  provider      String    // youtube, zoom, meet, instagram, custom
  title         String
  url           String
  scheduledAt   DateTime?
  status        String    @default("scheduled") // scheduled, live, ended
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  invitationId  String
  invitation    Invitation @relation(fields: [invitationId], references: [id])
}

model BillingOrder {
  id            String    @id @default(cuid())
  plan          String    // free, premium, pro
  amount        Int
  status        String    @default("pending") // pending, paid, cancelled
  paymentMethod String?   // bank_transfer, manual, gateway
  note          String?
  checkoutSessionId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId        String?
  user          User?      @relation(fields: [userId], references: [id])
  paymentTransactions PaymentTransaction[]
}

model Subscription {
  id            String    @id @default(cuid())
  plan          String    // free, premium, pro
  status        String    @default("inactive") // active, inactive, expired
  startsAt      DateTime  @default(now())
  expiresAt     DateTime?
  sourceOrderId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId        String
  user          User      @relation(fields: [userId], references: [id])
}

model PaymentTransaction {
  id                 String    @id @default(cuid())
  provider           String    // midtrans, xendit, manual
  externalId         String    @unique
  orderId            String
  amount             Int
  status             String    @default("pending") // pending, paid, failed, expired
  signatureVerified  Boolean   @default(false)
  rawPayload         Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  userId             String
  user               User      @relation(fields: [userId], references: [id])

  billingOrderId     String?
  billingOrder       BillingOrder? @relation(fields: [billingOrderId], references: [id])
}

model CheckoutSession {
  id            String    @id @default(cuid())
  themeKey      String
  groomName     String
  brideName     String
  plan          String
  email         String
  phone         String
  status        String    @default("draft") // draft, pending_payment, paid, completed, expired
  userId        String?
  note          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User?     @relation(fields: [userId], references: [id])
}

model EmailVerification {
  id            String    @id @default(cuid())
  email         String    @unique
  token         String    @unique
  verified      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Template {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  description   String?
  category      String    // "wedding", "birthday", "graduation"
  thumbnail     String?   // URL thumbnail
  previewImage  String?   // Preview image URL
  
  // Komponen template dalam JSON
  layout        Json      // Struktur layout page
  styles        Json?     // Custom CSS/theme config
  
  isPremium     Boolean   @default(false)
  isActive      Boolean   @default(true)
  isDefault     Boolean   @default(false)
  usageCount    Int       @default(0)
  
  createdBy     String?   // User ID yang membuat (null = system template)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relasi
  invitations   Invitation[]
  components    TemplateComponent[]
}

model TemplateComponent {
  id            String    @id @default(cuid())
  templateId    String
  template      Template  @relation(fields: [templateId], references: [id])
  
  type          String    // "hero", "countdown", "story", "gallery", "rsvp", "gift", "footer"
  order         Int
  config        Json      // Props untuk component
  isVisible     Boolean   @default(true)
  
  createdAt     DateTime  @default(now())
}
